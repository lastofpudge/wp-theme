{% extends 'views/woocommerce/emails/email-base.twig' %}

{% block body %}
	{% if first_name %}<p>Hi {{ first_name }},</p>{% else %}<p>Hi,</p>{% endif %}
	<p>Thank you for your order. It is currently on hold while we await payment confirmation. Your order details are shown below.</p>

	{{ order_details | raw }}
	{{ order_meta | raw }}
	{{ customer_details | raw }}
	{% if additional %}{{ additional | raw }}{% endif %}
{% endblock %}
