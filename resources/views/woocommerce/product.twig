{% extends 'layouts/base.twig' %}

{% block content %}
    {% do action('woocommerce_before_single_product') %}
    <div class="post-wrap" id="post-{{ product.get_id() }}">
        <div class="container">
            <div class="row">
                <div class="col-12 mb-3">
                    {% if fn('function_exists', 'yoast_breadcrumb') %}
                        {{ fn('yoast_breadcrumb', '<nav id="breadcrumbs" class="main-breadcrumbs">','</nav>', false ) }}
                    {% endif %}
                </div>
            </div>
            <div class="row">
                <div class="col-6">
                    {% include 'woocommerce/components/gallery.twig' %}
                </div>

                <div class="col-6">

                    <div class="summary entry-summary">
                        <h1 class="product_title entry-title">{{ product.get_name() }}</h1>

                        {% if product.get_short_description() %}
                            <div class="product-short-description mb-3">
                                {{ product.get_short_description()|raw }}
                            </div>
                        {% endif %}

                        <div class="price">
                            {{ product.get_price_html() | raw }}
                        </div>

                        <div class="stock-status mb-2">
                            {% if product.is_in_stock() %}
                                <span class="badge bg-success">{{ fn('__', 'In stock', 'woocommerce') }}</span>
                                {% if product.get_stock_quantity() %}
                                    <small class="text-muted ms-1">
                                        ({{ product.get_stock_quantity() }} {{ fn('__', 'left', 'woocommerce') }})
                                    </small>
                                {% endif %}
                            {% else %}
                                <span class="badge bg-danger">{{ fn('__', 'Out of stock', 'woocommerce') }}</span>
                            {% endif %}
                        </div>

                        {% if product.get_sku() %}
                        <div class="sku">
                            sku: <span>{{ product.get_sku() }}</span>
                        </div>
                        {% endif %}

                        {% if categories %}
                            <div class="categories">
                                categories:
                                <ul>
                                    {% for cat in categories %}
                                        <li>
                                            <a href="{{ cat.link }}">{{ cat.name }}</a>
                                        </li>
                                    {% endfor %}
                                </ul>
                            </div>
                        {% endif %}

                        {% if product.is_type('variable') %}
                            {% if product_variations %}
                                <table class="table table-bordered">
                                    <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Price</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for variation in product_variations %}
                                        <tr>
                                            {% if variation.name %}
                                                <td>{{ variation.name }}</td>
                                            {% else %}
                                                <td>N/A</td>
                                            {% endif %}
                                            <td>{{ variation.price_html|raw }}</td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>

                                <label>
                                    <select name="variation" class="js-variant">
                                        <option value="#" selected disabled>Select variation</option>
                                        {% for variation in product_variations %}
                                            <option value="{{ variation.variation_id }}">{{ variation.name }}</option>
                                        {% endfor %}
                                    </select>
                                </label>
                            {% else %}
                                <p>No variants found for this product.</p>
                            {% endif %}
                        {% endif %}

                        <div class="mt-2 mb-4">
                            <label>
                                <input
                                        class="js-product-qty"
                                        type="number"
                                        name="quantity"
                                        min="1"
                                        {% if product.get_stock_quantity() %}
                                            max="{{ product.get_stock_quantity() }}"
                                        {% endif %}
                                        value="1">
                            </label>
                        </div>

                        <div class="mt-2">
                            <button class="js-add-to-cart" data-quantity="1" data-product_id="{{ product.get_id() }}"
                                    {% if product.is_type('variable') %} disabled {% endif %}
                            >
                                Add to
                                Cart
                            </button>
                        </div>

                        <br>
                        {{ fn(
                            'edit_post_link',
                            'Edit',
                            '<span class="edit-link">',
                            '</span>',
                            post.ID
                        ) }}
                    </div>

                </div>
            </div>

            {# Tabs: Description, Additional info, Reviews #}
            <div class="row mt-5">
                <div class="col-12">
                    <div class="woocommerce-tabs">

                        <ul class="nav nav-tabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-description" role="tab">
                                    {{ fn('__', 'Description', 'woocommerce') }}
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-additional" role="tab">
                                    {{ fn('__', 'Additional information', 'woocommerce') }}
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-reviews" role="tab">
                                    {{ fn('__', 'Reviews', 'woocommerce') }}{% if reviews_count %} ({{ reviews_count }}){% endif %}
                                </button>
                            </li>
                        </ul>

                        <div class="tab-content pt-4">

                            <div class="tab-pane fade show active" id="tab-description" role="tabpanel">
                                {% if description %}
                                    <div class="entry-content">{{ description | raw }}</div>
                                {% else %}
                                    <p class="text-muted">{{ fn('__', 'No description available.', 'woocommerce') }}</p>
                                {% endif %}
                            </div>

                            <div class="tab-pane fade" id="tab-additional" role="tabpanel">
                                {% if product_attributes %}
                                    <table class="woocommerce-product-attributes shop_attributes table">
                                        <tbody>
                                        {% for attr in product_attributes %}
                                            <tr>
                                                <th class="woocommerce-product-attributes-item__label fw-semibold">{{ attr.label }}</th>
                                                <td class="woocommerce-product-attributes-item__value">{{ attr.values | join(', ') }}</td>
                                            </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>
                                {% else %}
                                    <p class="text-muted">{{ fn('__', 'No additional information available.', 'woocommerce') }}</p>
                                {% endif %}
                            </div>

                            <div class="tab-pane fade" id="tab-reviews" role="tabpanel">
                                {{ reviews_html | raw }}
                            </div>

                        </div>
                    </div>
                </div>
            </div>

            {# Upsells #}
            {% if upsells %}
            <div class="row mt-5">
                <div class="col-12">
                    <h2 class="mb-4">{{ fn('__', 'You may also like&hellip;', 'woocommerce') | raw }}</h2>
                    <div class="row row-cols-2 row-cols-md-4 g-4">
                        {% for post in upsells %}
                        <div class="col">
                            {% include 'woocommerce/components/product-card.twig' %}
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            {% endif %}

            {# Related products #}
            <div class="row">
                <div class="col-12">
                    {% include 'woocommerce/components/related.twig' %}
                </div>
            </div>

        </div>
    </div>
{% endblock %}
