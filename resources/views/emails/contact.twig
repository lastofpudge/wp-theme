<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width">
</head>
<body style="font-family:Calibri, sans-serif;">
<h2 style="text-align:center; color:#343434;font-size:24px;font-weight:700;letter-spacing:3px;line-height:35px;">
    Contact form — <span style="color:#5caad2;">{{ site_name }}</span>
</h2>
<table style="width:100%; border-collapse:collapse; background:#fff;">
    <tr style="background:#eee;">
        <td style="width:30%; padding:8px; font-weight:bold;">Name</td>
        <td style="width:70%; padding:8px;">{{ name }}</td>
    </tr>
    <tr>
        <td style="width:30%; padding:8px; font-weight:bold;">Email</td>
        <td style="width:70%; padding:8px;"><a href="mailto:{{ mail }}">{{ mail }}</a></td>
    </tr>
    {% if message %}
    <tr style="background:#eee;">
        <td style="width:30%; padding:8px; font-weight:bold;">Message</td>
        <td style="width:70%; padding:8px;">{{ message|nl2br }}</td>
    </tr>
    {% endif %}
</table>
</body>
</html>
