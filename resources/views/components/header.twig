<header>
    <div class="container">
        <div class="row">
            <div class="col-12">
                <nav class="navbar navbar-expand-lg navbar-light">
                    <a class="navbar-brand" href="{{ site_url }}">
                        {% if logo %}
                            {{ logo | raw }}
                        {% else %}
                            {{ site_name }}
                        {% endif %}
                    </a>

                    {% if main_menu %}
                        <ul class="navbar-nav me-auto">
                            {% for item in main_menu.get_items %}
                                <li class="mx-2 nav-item {{ item.classes|join(' ') }}{{ item.current ? ' active' }}">
                                    <a class="nav-main-link" href="{{ item.link }}">{{ item.title }}</a>
                                    {% if item.children %}
                                        <ul class="nav-drop">
                                            {% for child in item.children %}
                                                <li class="nav-drop-item">
                                                    <a href="{{ child.link }}">{{ child.title }}</a>
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    {% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}

                    {% if languages %}
                        <select class="form-select form-select-sm me-3 w-auto"
                                onchange="window.location.href=this.value">
                            {% for lang in languages %}
                                <option value="{{ lang.url }}" {% if lang.current_lang %}selected{% endif %}>
                                    {{ lang.name }}
                                </option>
                            {% endfor %}
                        </select>
                    {% endif %}

                    <div class="navbar-nav ms-auto align-items-center gap-3">
                        <a class="nav-link" href="{{ cart_link }}">
                            <i class="fa-solid fa-cart-shopping"></i> Cart
                            {% if cart and cart.get_cart_contents_count() > 0 %}
                                <span class="badge bg-danger">{{ cart.get_cart_contents_count() }}</span>
                            {% endif %}
                        </a>
                        <a class="nav-link" href="{{ checkout_link }}">
                            <i class="fa-solid fa-credit-card"></i> Checkout
                        </a>
                        {% if cart %}
                            {% include 'woocommerce/components/cartSmall.twig' %}
                        {% endif %}
                    </div>
                </nav>
            </div>
        </div>
    </div>
</header>
