{% extends 'layouts/base.twig' %}

{% block content %}

    {# ==============================
       HERO — replace with your banner
       ============================== #}
    <section class="hero">
        <div class="container py-5">
            <h1>{{ site.name }}</h1>
            <a href="{{ wc_page_url('shop') }}" class="btn btn-primary">
                {{ fn('__', 'Shop now', 'woocommerce') }}
            </a>
        </div>
    </section>

    {# ==============================
       BESTSELLERS
       ============================== #}
    {% if bestsellers %}
        <section class="section-bestsellers py-5">
            <div class="container">
                <h2 class="section-title mb-4">{{ fn('__', 'Bestsellers', 'woocommerce') }}</h2>
                <div class="row row-cols-2 row-cols-md-4 g-3">
                    {% for post in bestsellers %}
                        <div class="col">
                            {% include 'woocommerce/components/product-card.twig' %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}

    {# ==============================
       NEW ARRIVALS
       ============================== #}
    {% if new_arrivals %}
        <section class="section-new-arrivals py-5 bg-light">
            <div class="container">
                <h2 class="section-title mb-4">{{ fn('__', 'New arrivals', 'woocommerce') }}</h2>
                <div class="row row-cols-2 row-cols-md-4 g-3">
                    {% for post in new_arrivals %}
                        <div class="col">
                            {% include 'woocommerce/components/product-card.twig' %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}

    {# ==============================
       ON SALE
       ============================== #}
    {% if on_sale %}
        <section class="section-on-sale py-5">
            <div class="container">
                <h2 class="section-title mb-4">{{ fn('__', 'On sale', 'woocommerce') }}</h2>
                <div class="row row-cols-2 row-cols-md-4 g-3">
                    {% for post in on_sale %}
                        <div class="col">
                            {% include 'woocommerce/components/product-card.twig' %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}

    {# ==============================
       FEATURED
       ============================== #}
    {% if featured %}
        <section class="section-featured py-5 bg-light">
            <div class="container">
                <h2 class="section-title mb-4">{{ fn('__', 'Featured products', 'woocommerce') }}</h2>
                <div class="row row-cols-2 row-cols-md-4 g-3">
                    {% for post in featured %}
                        <div class="col">
                            {% include 'woocommerce/components/product-card.twig' %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}

    {# ==============================
       TOP RATED
       ============================== #}
    {% if top_rated %}
        <section class="section-top-rated py-5">
            <div class="container">
                <h2 class="section-title mb-4">{{ fn('__', 'Top rated', 'woocommerce') }}</h2>
                <div class="row row-cols-2 row-cols-md-4 g-3">
                    {% for post in top_rated %}
                        <div class="col">
                            {% include 'woocommerce/components/product-card.twig' %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}

{% endblock %}
